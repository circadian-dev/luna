{
  "name": "@circadian/luna",
  "version": "0.1.2",
  "type": "module",
  "description": "Lunar-aware React widgets that follow the real phase of the moon.",
  "homepage": "https://circadian.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/circadian-dev/luna"
  },
  "bugs": {
    "url": "https://github.com/circadian-dev/luna/issues"
  },
  "license": "MIT",
  "author": "Circadian",
  "keywords": [
    "react",
    "lunar",
    "moon",
    "widget",
    "theme",
    "circadian",
    "ambient",
    "phase"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./devtools": {
      "default": "./dist/devtools/index.js",
      "types": "./dist/devtools/index.d.ts"
    },
    "./styles.css": "./dist/styles.css",
    "./styles-no-preflight.css": "./dist/styles-no-preflight.css"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown && bunx @tailwindcss/cli -i src/styles.css -o dist/styles.css --minify && bunx @tailwindcss/cli -i src/styles-no-preflight.css -o dist/styles-no-preflight.css --minify",
    "dev": "concurrently \"tsdown --watch\" \"bunx @tailwindcss/cli -i src/styles.css -o dist/styles.css --watch\"",
    "typecheck": "tsc --noEmit --pretty",
    "lint": "biome check --error-on-warnings ./src",
    "format": "biome format --write .",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "@circadian/sol": "^0.2.9",
    "countries-and-timezones": "^3.6.0",
    "motion": "^11.0.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@tailwindcss/cli": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.6",
    "@types/react-dom": "^18.3.0",
    "concurrently": "^9.0.0",
    "tailwindcss": "^4.2.2",
    "tsdown": "^0.15.9",
    "typescript": "^5.7.0"
  },
  "packageManager": "bun@1.2.16"
}
