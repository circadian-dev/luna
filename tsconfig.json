{
  "compilerOptions": {
    "target":            "ES2020",
    "module":            "ESNext",
    "moduleResolution":  "bundler",
    "lib":               ["ES2020", "DOM", "DOM.Iterable"],
    "jsx":               "react-jsx",
    "strict":            true,
    "declaration":       true,
    "declarationMap":    true,
    "sourceMap":         true,
    "esModuleInterop":   true,
    "skipLibCheck":      true,
    "outDir":            "./dist",
    "rootDir":           "./src",
    "paths": {
      "@circadian/sol": ["../sol/dist/index.d.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}